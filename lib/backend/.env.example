# Sao chép file này thành .env và điền giá trị thực

# Kết nối MySQL (dùng aiomysql driver)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=poturex123
DB_USER=root
# KHONG dat mat khau that o day — file nay duoc commit len git.
DB_PASSWORD=your-mysql-password

# Khóa bí mật sinh JWT — thay bằng chuỗi ngẫu nhiên dài trong production
SECRET_KEY=change-me-to-a-long-random-secret

# Thư mục lưu video (tương đối so với thư mục chạy uvicorn)
VIDEO_STORAGE_PATH=storage/videos

# Debug mode — đặt False trong production
DEBUG=False

# Gửi email OTP xác thực đăng ký (SMTP Gmail — dùng App Password, không phải mật khẩu Gmail thường)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraccount@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=Posture X

# Google Sign-In — "Web application" OAuth 2.0 client ID from Google Cloud
# Console (Credentials page). Must match the serverClientId configured in
# the Flutter app's lib/config/api_config.dart.
GOOGLE_CLIENT_ID=

# MoMo (BE-14) — cổng thanh toán đang dùng.
# KHÔNG CẦN ĐIỀN GÌ để chạy thử: mặc định trong config.py là bộ khoá sandbox
# CÔNG KHAI của MoMo (repo mẫu chính thức github.com/momo-wallet/payment).
# Nó không tiêu được tiền thật. Lên production mới phải điền khoá thật vào đây.
#MOMO_PARTNER_CODE=
#MOMO_ACCESS_KEY=
#MOMO_SECRET_KEY=
# Emulator gọi được 10.0.2.2 (= localhost của máy host). Đổi sang IP LAN nếu
# test trên điện thoại thật.
#MOMO_REDIRECT_URL=http://10.0.2.2:9000/api/v1/payments/momo/return

# Firebase Cloud Messaging (BE-13) — push notification.
# Lấy file khoá: Firebase Console > Project settings > Service accounts >
# Generate new private key. File này ĐÃ BỊ .gitignore chặn — đừng commit.
# Bỏ trống thì push bị bỏ qua trong im lặng, thông báo trong app vẫn chạy.
FCM_CREDENTIALS_FILE=
FCM_PROJECT_ID=

# Job định kỳ (BE-13) — giờ tính theo múi giờ Việt Nam.
REMINDERS_ENABLED=True
BREAK_REMINDER_HOURS=10,15
DAILY_SUMMARY_HOUR=20
